# LLM Provider: mock, openai, or anthropic
LLM_PROVIDER=mock

# API Keys (optional — mock mode works without keys)
# These are passed as environment variables to the Docker services.
# For production, consider using Docker secrets instead.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://conspiracy:conspiracy@localhost:5432/conspiracy
REDIS_URL=redis://localhost:6379/0

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=conspiracy
POSTGRES_PASSWORD=conspiracy
POSTGRES_DB=conspiracy
POSTGRES_PORT=5432